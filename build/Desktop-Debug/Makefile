	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o ../../main.cpp

dialog.o: ../../dialog.cpp ../../dialog.h \
		ui_dialog.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o dialog.o ../../dialog.cpp

